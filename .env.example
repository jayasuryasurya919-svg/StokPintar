APP_NAME=StokPintar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production checklist:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Production session example:
# SESSION_DRIVER=database
# SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Production queue example:
# QUEUE_CONNECTION=database
# Run a queue worker so reset password and invitation emails are processed reliably.

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production SMTP example:
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password
# MAIL_FROM_ADDRESS="noreply@stokpintar.test"
# MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth login:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Payment gateway setup:
# Keep PAYMENT_PROVIDER=manual for demo/manual subscription handling.
# Use "midtrans" or "xendit" only after the keys below are filled in production.
PAYMENT_PROVIDER=manual

# Midtrans example:
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
# Set this route as Payment Notification URL in Midtrans dashboard:
# ${APP_URL}/payments/midtrans/notification

# Xendit example:
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
